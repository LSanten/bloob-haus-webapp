{#
  banner.njk — Object-aware banner for marbles-pouch theme.

  Uses bloob_object (set by preprocessor from frontmatter `bloob-object:`) to look up
  image + banner_text + description from the bloobObjects data file.

  Falls back to site title/description when no object type is set (e.g. homepage).
#}

{% set objType = bloob_object %}
{% set objData = bloobObjects[objType] if objType and bloobObjects[objType] %}

{# Resolve banner image: _bloob-objects.md path → theme asset → marble.png fallback #}
{# "default" in image column means "use theme default" — treat as unset #}
{% if objData and objData.image and objData.image != "default" %}
  {% set bannerImage = objData.image %}
{% elif objType %}
  {% set bannerImage = "/assets/objects/" + objType + ".png" %}
{% else %}
  {% set bannerImage = "/assets/objects/marble.png" %}
{% endif %}

{# Resolve banner text #}
{% if objData and objData.banner_text %}
  {% set bannerText = objData.banner_text %}
{% elif page.url == "/" %}
  {% set bannerText = site.description %}
{% else %}
  {% set bannerText = null %}
{% endif %}

{# Resolve display name for the modal button label #}
{% if objData and objData.display_name %}
  {% set objLabel = objData.display_name | lower %}
{% elif objType %}
  {% set objLabel = objType %}
{% else %}
  {% set objLabel = "this" %}
{% endif %}

<div class="site-banner">
  <div class="site-banner__inner">

    {% if bannerImage %}
    <img
      class="site-banner__image no-zoom"
      src="{{ bannerImage | url }}"
      alt="{{ objLabel }} image"
      width="200"
    />
    {% endif %}

    {% if page.url == "/" %}
    <h1 class="site-banner__site-title">{{ site.title }}</h1>
    {% endif %}

    {% if bannerText %}
    <p class="site-banner__text">{{ bannerText }}</p>
    {% endif %}

    {% if page.url != "/" %}
    {#
      Byline resolution:
      1. `byline` frontmatter — write the full text yourself (replaces "Yours," entirely).
         Supports [text](url) links and literal newlines (use YAML block scalar with |).
      2. `author` frontmatter — replaces just the name after "Yours,"
      3. site.author from _bloob-settings.md
    #}
    {% if byline %}
    <p class="site-banner__byline">{{ byline | mdLinks | nl2br | safe }}</p>
    {% else %}
    {% set bylineAuthor = author if author else site.author %}
    <p class="site-banner__byline">Yours, {{ bylineAuthor | mdLinks | safe }}</p>
    {% endif %}
    {% endif %}

    {% if objData and objData.description %}
    <button
      class="site-banner__info-btn"
      id="banner-modal-trigger"
      aria-haspopup="dialog"
    >✨ What is a {{ objLabel }}?</button>
    {% endif %}

  </div>

  {# Decorative shapes — uses theme assets/objects/*.png images #}
  <img class="banner-shape banner-shape--1 no-zoom" src="{{ "/assets/objects/shape-2.png" | url }}" alt="" aria-hidden="true" width="80">
  <img class="banner-shape banner-shape--2 no-zoom" src="{{ "/assets/objects/shape-4.png" | url }}" alt="" aria-hidden="true" width="65">
  <img class="banner-shape banner-shape--3 no-zoom" src="{{ "/assets/objects/shape-3.png" | url }}" alt="" aria-hidden="true" width="80">

  {# Bottom wave — gentle wave, all y-values within viewBox (no off-screen peaks) #}
  <svg class="site-banner__wave" viewBox="0 0 2204 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
    <path d="M0,65 C300,25 600,80 900,50 C1200,22 1500,75 1800,45 C2000,28 2150,65 2204,60 L2204,100 L0,100 Z"/>
  </svg>
</div>
