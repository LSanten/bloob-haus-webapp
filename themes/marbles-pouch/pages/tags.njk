---
layout: layouts/base.njk
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - nav
    - posts
    - tagList
    - not-for-public
    - sections
    - withBacklinks
permalink: /tags/{{ tag | slugify }}/
eleventyComputed:
  title: "Tagged: {{ tag }}"
eleventyExcludeFromCollections: true
---
<div class="tag-page">
  <h1>Marbles tagged "{{ tag }}"</h1>

  <ul class="recent-marbles__list">
  {% set taglist = collections[tag] %}
  {% for post in taglist | reverse %}
    <li>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      {% if post.date %}
      <span class="recent-marbles__date">{{ post.date | dateFormat }}</span>
      {% endif %}
    </li>
  {% endfor %}
  </ul>

  <p style="margin-top: 1.5rem;"><a href="{{ "/tags/" | url }}">&larr; All tags</a></p>
</div>
