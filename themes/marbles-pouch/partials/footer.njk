<footer class="site-footer">
  {# Top wave — gentle wave, fills white downward (all y-values within viewBox) #}
  <svg class="site-footer__wave" viewBox="0 0 2204 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
    <path d="M0,80 C300,30 600,100 900,55 C1200,22 1500,88 1800,48 C2000,28 2150,78 2204,70 L2204,120 L0,120 Z"/>
  </svg>

  <div class="site-footer__inner">
    <ul class="site-footer__links">
      <li><a href="{{ "/" | url }}">home</a></li>
      {% if site.author and site.author.email %}
      <li><a href="mailto:{{ site.author.email }}">email</a></li>
      {% endif %}
      {% if site.author and site.author.linkedin %}
      <li><a href="{{ site.author.linkedin }}" target="_blank" rel="noopener">linkedin</a></li>
      {% endif %}
      <li><a href="{{ "/feed.xml" | url }}">rss</a></li>
    </ul>

    <div class="site-footer__license">
      {% if site.footer_text %}
        {{ site.footer_text }}
      {% else %}
        <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener">
          <img src="https://mirrors.creativecommons.org/presskit/logos/cc.logo.svg" alt="Creative Commons" />
        </a>
        CC BY-NC-SA 4.0
      {% endif %}
    </div>
  </div>
</footer>
