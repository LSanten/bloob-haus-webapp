<!-- Visualizers (auto-generated from lib/visualizers/) -->
{% for vis in visualizers %}{% if vis.hasJs %}
<script src="{{ ("/assets/js/visualizers/" + vis.name + ".js") | url }}"></script>
{% endif %}{% endfor %}

<!-- External links in new tab — on by default (opt-out via features.external_links_new_tab: false) -->
{% if site.features.external_links_new_tab != false %}
<script>
  document.querySelectorAll('article a[href^="http"]').forEach(function(a) {
    if (!a.hostname || a.hostname !== location.hostname) {
      a.setAttribute('target', '_blank');
      a.setAttribute('rel', 'noopener');
    }
  });
</script>
{% endif %}
